<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Corpo Jurídico | Especialistas</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Lato:wght@300;400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        :root {
            --fundo-pagina: #f0f2f8; /* Tom de cinza azulado profissional */
            --azul-escuro: #0c133f;
            --dourado-serio: #b38e5d; /* Dourado mais metálico e menos amarelo */
            --branco-puro: #ffffff;
            --fonte-seria: 'Playfair Display', serif;
            --fonte-corpo: 'Lato', sans-serif;
        }

        body {
            background-color: var(--fundo-pagina);
            color: var(--azul-escuro);
            font-family: var(--fonte-corpo);
            margin: 0;
            padding: 80px 20px;
            -webkit-font-smoothing: antialiased;
        }

        header {
            text-align: center;
            max-width: 800px;
            margin: 0 auto 80px auto;
        }

        header h1 {
            font-family: var(--fonte-seria);
            font-size: 2.8rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-bottom: 20px;
            position: relative;
            display: inline-block;
        }

        header h1::after {
            content: '';
            position: absolute;
            bottom: -10px;
            left: 25%;
            width: 50%;
            height: 2px;
            background-color: var(--dourado-serio);
        }

        header p {
            font-size: 1.1rem;
            color: #555;
            font-weight: 300;
            margin-top: 25px;
        }

        .team-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 25px;
            max-width: 1400px;
            margin: 0 auto;
        }

        /* Card Moderno e Sóbrio */
        .card {
            background-color: var(--branco-puro);
            border-left: 4px solid var(--azul-escuro); /* Detalhe de sobriedade */
            padding: 35px 25px;
            display: flex;
            align-items: center;
            transition: all 0.3s ease-in-out;
            box-shadow: 0 5px 15px rgba(0,0,0,0.05);
            position: relative;
        }

        /* Efeito de Hover - Refinado */
        .card:hover {
            transform: translateY(-5px);
            border-left-color: var(--dourado-serio);
            box-shadow: 0 15px 35px rgba(12, 19, 63, 0.1);
        }

        .photo-area {
            width: 90px;
            height: 90px;
            background-color: #f8f9fa;
            border: 1px solid #eee;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 25px;
            flex-shrink: 0;
        }

        .photo-area i {
            font-size: 2.2rem;
            color: #ccc;
        }

        .info {
            border-left: 1px solid #eee;
            padding-left: 25px;
        }

        .info h2 {
            font-family: var(--fonte-seria);
            font-size: 1.4rem;
            margin: 0 0 5px 0;
            color: var(--azul-escuro);
        }

        .cargo {
            display: block;
            font-size: 0.8rem;
            font-weight: 700;
            color: var(--dourado-serio);
            text-transform: uppercase;
            letter-spacing: 1.5px;
            margin-bottom: 15px;
        }

        .details {
            list-style: none;
            padding: 0;
            margin: 0;
        }

        .details li {
            font-size: 0.85rem;
            margin-bottom: 8px;
            display: flex;
            align-items: center;
            color: #444;
            font-weight: 400;
        }

        .details li i {
            color: var(--azul-escuro);
            width: 18px;
            margin-right: 12px;
            font-size: 0.9rem;
            opacity: 0.8;
        }

        /* Responsividade Total */
        @media (max-width: 1200px) {
            .team-grid { grid-template-columns: repeat(2, 1fr); }
        }

        @media (max-width: 768px) {
            .team-grid { grid-template-columns: 1fr; }
            .card { padding: 25px; }
            header h1 { font-size: 2rem; }
        }
    </style>
</head>
<body>

    <header>
        <h1>Corpo Jurídico</h1>
        <p>Excelência técnica e compromisso ético na defesa de seus interesses corporativos e individuais.</p>
    </header>

    <div class="team-grid" id="grid-equipe">
        </div>

    <script>
        const especialistas = [
            "Direito Societário", "Compliance & Ética", "Gestão Tributária", 
            "Contencioso Civil", "Propriedade Intelectual", "Relações de Trabalho", 
            "Direito Imobiliário", "Fusões e Aquisições"
        ];

        const container = document.getElementById('grid-equipe');

        especialistas.forEach((area) => {
            container.innerHTML += `
                <div class="card">
                    <div class="photo-area">
                        <i class="fas fa-user"></i>
                    </div>
                    <div class="info">
                        <h2>Nome do Advogado</h2>
                        <span class="cargo">Sócio Especialista</span>
                        <ul class="details">
                            <li><i class="fas fa-balance-scale"></i> ${area}</li>
                            <li><i class="fas fa-award"></i> Carreira Consolidada</li>
                            <li><i class="fas fa-graduation-cap"></i> Formação Acadêmica de Elite</li>
                            <li><i class="fas fa-shield-halved"></i> Projetos Estratégicos</li>
                        </ul>
                    </div>
                </div>
            `;
        });
    </script>

</body>
</html>
